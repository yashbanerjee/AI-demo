---
import Preloader from "../components/Preloader.astro";
import Header from "../components/Header.astro";
import MenuOverlay from "../components/MenuOverlay.astro";
import Footer from "../components/Footer.astro";
import BookingModal from "../components/BookingModal.astro";
import ServiceEnquiryModal from "../components/ServiceEnquiryModal.astro";
import { getSeoForPath } from "../lib/db";
import "@fontsource-variable/inter";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  publishedTime?: Date;
  modifiedTime?: Date;
  prevPage?: string;
  nextPage?: string;
  preloadHeroPoster?: boolean;
  preloadHeroImage?: string;
}

const props = Astro.props;

// Per-page overrides managed in the admin panel take priority over page defaults
const seoOverride = await getSeoForPath(Astro.url.pathname);

const title = seoOverride?.title || props.title;
const description =
  seoOverride?.description ||
  props.description ||
  "Vedha is a Dubai-based technology agency delivering web development, UI/UX, e-commerce, AI and digital transformation services.";
const ogImage = seoOverride?.og_image || props.ogImage || "/og-image.png";
const {
  ogType = "website",
  publishedTime,
  modifiedTime,
  prevPage,
  nextPage,
  preloadHeroPoster = false,
  preloadHeroImage,
} = props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageAbsolute = new URL(ogImage, Astro.site);

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Vedha Technologies",
  url: Astro.site?.toString(),
  logo: new URL("/images/vedha-logo.png", Astro.site).toString(),
  description:
    "Dubai-based technology agency delivering web development, UI/UX, e-commerce, AI and digital transformation services.",
  email: "info@vedha.ae",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Dubai",
    addressCountry: "AE",
  },
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "VEDHA",
  url: Astro.site?.toString(),
  inLanguage: "en",
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#0e0e0e" media="(prefers-color-scheme: dark)" />
  <meta name="theme-color" content="#f4f4f2" media="(prefers-color-scheme: light)" />
  <meta name="color-scheme" content="light" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="VEDHA" />
  <meta name="application-name" content="VEDHA" />
  <meta name="format-detection" content="telephone=no" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
  <link rel="sitemap" href="/sitemap.xml" />
  <link rel="alternate" type="application/rss+xml" title="VEDHA Blog" href={new URL("/rss.xml", Astro.site)} />
  {prevPage && <link rel="prev" href={new URL(prevPage, Astro.site)} />}
  {nextPage && <link rel="next" href={new URL(nextPage, Astro.site)} />}
  {preloadHeroPoster && <link rel="preload" as="image" href="/videos/hero-3d-poster.jpg" fetchpriority="high" />}
  {preloadHeroImage && <link rel="preload" as="image" href={preloadHeroImage} fetchpriority="high" />}
  <meta property="og:site_name" content="VEDHA" />
  <meta property="og:locale" content="en_AE" />
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImageAbsolute} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  {publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
  {modifiedTime && <meta property="article:modified_time" content={modifiedTime.toISOString()} />}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageAbsolute} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(organizationSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(websiteSchema)} />
</head>
<body>
  <a class="skip-link" href="#top">Skip to content</a>
  <Preloader />
  <Header />
  <MenuOverlay />
  <main id="top">
    <slot />
  </main>
  <Footer />
  <BookingModal />
  <ServiceEnquiryModal />
  <script src="../scripts/main.js"></script>
  <script src="../scripts/pwa.js"></script>
</body>
</html>
