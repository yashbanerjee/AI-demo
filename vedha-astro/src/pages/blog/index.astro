---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { listPosts } from "../../lib/db";

const PAGE_SIZE = 10;
const allPosts = await listPosts();
const pageParam = Number(Astro.url.searchParams.get("page") ?? "1");
const lastPage = Math.max(1, Math.ceil(allPosts.length / PAGE_SIZE));
const currentPage = Math.min(Math.max(1, pageParam || 1), lastPage);
const posts = allPosts.slice((currentPage - 1) * PAGE_SIZE, currentPage * PAGE_SIZE);

const coverFallback: Record<string, string> = {
  "from-idea-to-execution-building-products-that-last":
    "https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=1600&q=80",
  "where-ai-adds-value-in-web-development":
    "https://images.unsplash.com/photo-1677442136019-21780ecad995?auto=format&fit=crop&w=1600&q=80",
  "ecommerce-that-balances-experience-with-efficiency":
    "https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?auto=format&fit=crop&w=1600&q=80",
  "designing-digital-systems-that-scale-your-business":
    "https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=1600&q=80",
};

const coverOf = (slug: string, img: string | null) =>
  img ||
  coverFallback[slug] ||
  `https://picsum.photos/seed/vedha-blog-${slug}/480/360`;

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---
<BaseLayout
  title="Blog — VEDHA"
  description="Smart insights on web development, AI, e-commerce and digital transformation from the Vedha team in Dubai."
>
  <section class="blog blog--page" id="news">
    <header class="section-head">
      <div>
        <p class="kicker" data-reveal>(Blog)</p>
        <h1 class="giant" data-reveal>Smart insights.</h1>
      </div>
    </header>
    <ul class="blog__list">
      {posts.map((post) => (
        <li data-reveal>
          <a href={`/blog/${post.slug}/`} class="blog-row">
            <figure class="blog-row__media">
              <img
                src={coverOf(post.slug, post.cover_image)}
                alt=""
                width="480"
                height="360"
                loading="lazy"
              />
            </figure>
            <div class="blog-row__copy">
              <time datetime={post.pub_date.toISOString().split("T")[0]}>{formatDate(post.pub_date)}</time>
              <h3>{post.title}</h3>
            </div>
            <span class="blog-row__arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
    {lastPage > 1 && (
      <nav class="blog-pagination" aria-label="Blog pagination">
        {currentPage > 1 ? (
          <a class="btn btn--ghost" href={`/blog/?page=${currentPage - 1}`}><span>← Newer</span></a>
        ) : (
          <span />
        )}
        <p>Page {currentPage} of {lastPage}</p>
        {currentPage < lastPage ? (
          <a class="btn btn--ghost" href={`/blog/?page=${currentPage + 1}`}><span>Older →</span></a>
        ) : (
          <span />
        )}
      </nav>
    )}
  </section>
</BaseLayout>

<style>
  .blog--page {
    padding-top: calc(4.5rem + clamp(2rem, 6vh, 4rem));
    min-height: 70vh;
    max-width: var(--content-max);
    margin-inline: auto;
    width: 100%;
  }
  .blog-pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 3rem;
    color: var(--ink-soft);
  }
</style>
