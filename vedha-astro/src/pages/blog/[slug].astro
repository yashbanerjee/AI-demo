---
import { marked } from "marked";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPostBySlug, listPosts } from "../../lib/db";

const post = await getPostBySlug(Astro.params.slug!);
if (!post || post.draft) {
  return new Response("Not found", { status: 404 });
}

const { title, description, content, author, tags, cover_image, pub_date, updated_date, slug } = post;
const html = marked.parse(content);
const wordCount = content.replace(/[#*_`>\[\]()]/g, " ").trim().split(/\s+/).filter(Boolean).length;

const allPosts = await listPosts();
const otherPosts = allPosts.filter((p) => p.slug !== slug);

const cover =
  cover_image ||
  "/images/showreel-dubai.png";

const thumbOf = (s: string, img: string | null) =>
  img ||
  "/images/showreel-dubai.png";

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

const formatShort = (date: Date) =>
  date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });

const postSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  keywords: tags.join(", "),
  articleSection: tags[0] ?? "Insights",
  wordCount,
  datePublished: pub_date.toISOString(),
  ...(updated_date && { dateModified: updated_date.toISOString() }),
  image: new URL("/og-image.png", Astro.site).toString(),
  author: { "@type": "Organization", name: author, url: Astro.site?.toString() },
  publisher: {
    "@type": "Organization",
    name: "Vedha Technologies",
    logo: { "@type": "ImageObject", url: new URL("/images/vedha-logo.png", Astro.site).toString() },
  },
  mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).toString(),
};
---
<BaseLayout
  title={`${title} — VEDHA Blog`}
  description={description}
  ogType="article"
  publishedTime={pub_date}
  modifiedTime={updated_date ?? undefined}
  ogImage="/og-image.png"
>
  <div class="post-layout">
    <aside class="post-aside" data-reveal>
      <p class="post-aside__kicker">All posts</p>
      <nav class="post-aside__nav" aria-label="Other blog posts">
        <ul>
          {otherPosts.map((p) => (
            <li>
              <a href={`/blog/${p.slug}/`} class="post-aside__link">
                <img
                  src={thumbOf(p.slug, p.cover_image)}
                  alt={`${p.title} article cover`}
                  width="96"
                  height="72"
                  loading="lazy"
                />
                <span>
                  <time datetime={p.pub_date.toISOString().split("T")[0]}>{formatShort(p.pub_date)}</time>
                  <strong>{p.title}</strong>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <a class="post-aside__all" href="/blog/">View blog index →</a>
    </aside>

    <article class="post">
      <header class="post__header">
        <p class="kicker">
          (Blog)
          {tags.length > 0 && <>&ensp;[{tags.join(" · ")}]</>}
        </p>
        <h1 class="post__title">{title}</h1>
        <p class="post__meta">
          <time datetime={pub_date.toISOString().split("T")[0]}>{formatDate(pub_date)}</time>
          <span aria-hidden="true">·</span>
          <span>{author}</span>
        </p>
      </header>

      <figure class="post__cover">
        <img src={cover} alt={`${title} article cover`} width="1600" height="900" loading="eager" />
      </figure>

      <div class="post__prose" set:html={html} />

      <footer class="post__footer">
        <a class="btn btn--ghost" href="/blog/"><span>← All posts</span></a>
        <a class="btn btn--dark" href="/#book" data-book-consultation><span>Book a free consultation</span></a>
      </footer>
    </article>
  </div>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(postSchema)} />
</BaseLayout>

<style>
  .post-layout {
    width: 100%;
    max-width: var(--content-max);
    margin-inline: auto;
    padding: calc(4.5rem + clamp(2rem, 6vh, 4rem)) var(--gutter) clamp(3rem, 8vh, 6rem);
    display: grid;
    gap: clamp(2.5rem, 5vw, 4rem);
    grid-template-columns: 1fr;
    align-items: start;
  }

  .post-aside {
    display: grid;
    gap: 1rem;
    align-content: start;
  }
  .post-aside__kicker {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .post-aside__nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.15rem;
    border-top: 1px solid var(--line);
  }
  .post-aside__link {
    display: grid;
    grid-template-columns: 4.25rem minmax(0, 1fr);
    gap: 0.75rem;
    align-items: center;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--line);
    text-decoration: none;
    color: inherit;
    transition: opacity 0.25s, transform 0.3s var(--ease-out);
  }
  .post-aside__link:hover {
    opacity: 0.72;
    transform: translateX(0.2rem);
  }
  .post-aside__link img {
    width: 4.25rem;
    height: 3.15rem;
    object-fit: cover;
    border-radius: 0.45rem;
    background: var(--dark);
  }
  .post-aside__link span {
    display: grid;
    gap: 0.2rem;
    min-width: 0;
  }
  .post-aside__link time {
    font-size: 0.68rem;
    color: var(--ink-soft);
    letter-spacing: 0.04em;
  }
  .post-aside__link strong {
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-aside__all {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.25s;
  }
  .post-aside__all:hover { color: var(--ink); }

  .post {
    min-width: 0;
    max-width: 44rem;
    display: grid;
    gap: clamp(1.6rem, 3vh, 2.4rem);
  }
  .post__header { display: grid; gap: 0.9rem; }
  .post__title {
    font-size: clamp(2.1rem, 5vw, 3.4rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.05;
    max-width: 18ch;
  }
  .post__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--ink-soft);
    font-size: 0.95rem;
  }
  .post__cover {
    margin: 0;
    overflow: hidden;
    border-radius: var(--radius);
    aspect-ratio: 16 / 9;
    background: var(--dark);
  }
  .post__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .post__prose {
    display: grid;
    gap: 1.15rem;
    font-size: 1.05rem;
    line-height: 1.7;
    color: rgba(17, 17, 17, 0.88);
  }
  .post__prose :global(h2) {
    margin-top: 1.1rem;
    font-size: clamp(1.25rem, 2.2vw, 1.55rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.25;
    color: var(--ink);
  }
  .post__prose :global(p) { margin: 0; }
  .post__prose :global(a) {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }
  .post__prose :global(blockquote) {
    margin: 0.4rem 0;
    padding: 0.85rem 0 0.85rem 1.1rem;
    border-left: 2px solid rgba(17, 17, 17, 0.18);
    color: var(--ink-soft);
    font-style: italic;
  }
  .post__prose :global(img) {
    width: 100%;
    height: auto;
    border-radius: calc(var(--radius) * 0.85);
    margin: 0.4rem 0;
  }
  .post__prose :global(ul),
  .post__prose :global(ol) {
    padding-left: 1.2rem;
    display: grid;
    gap: 0.4rem;
  }
  .post__footer {
    margin-top: 0.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
  }

  @media (min-width: 64rem) {
    .post-layout {
      grid-template-columns: minmax(15rem, 17.5rem) minmax(0, 44rem);
      justify-content: center;
    }
    .post-aside {
      position: sticky;
      top: 6rem;
    }
  }

  @media (max-width: 63.99rem) {
    .post-aside {
      order: 2;
      padding-top: 0.5rem;
      border-top: 1px solid var(--line);
    }
    .post { order: 1; max-width: none; }
    .post__title { max-width: none; }
  }
</style>
