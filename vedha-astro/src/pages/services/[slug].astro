---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllCategories, getCategoryBySlug } from "../../data/services.js";
import { breadcrumbSchema, serviceSchema } from "../../lib/schema";

const category = getCategoryBySlug(Astro.params.slug!);
if (!category) {
  return new Response("Not found", { status: 404 });
}

const all = getAllCategories();
const siblings = all.filter(
  (c) => c.pillar === category.pillar && c.slug !== category.slug
);
const related =
  siblings.length > 0
    ? siblings.slice(0, 3)
    : all.filter((c) => c.slug !== category.slug).slice(0, 3);

const description = category.description;
const cover = "/images/showreel-dubai.png";
const pagePath = `/services/${category.slug}/`;
const schema = [
  breadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Services", path: "/services/" },
    { name: category.name, path: pagePath },
  ]),
  serviceSchema({
    name: category.name,
    description,
    path: pagePath,
    services: category.services,
  }),
];
const serviceId = (name: string) =>
  `service-${name.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/-$/, "")}`;
---
<BaseLayout
  title={`${category.name} — VEDHA`}
  description={description}
  ogImage="/og-image.png"
>
  <article class="svc-cat" id="svcCatPage">
    <figure class="scene-banner" data-scene-banner>
      <img
        src={cover}
        alt=""
        width="1800"
        height="1000"
        loading="eager"
        decoding="async"
        aria-hidden="true"
      />
      <h1 class="scene-banner__title">{category.name}</h1>
      <figcaption class="scene-banner__meta">
        <span>{category.pillar}</span>
        <span>{category.services.length} services</span>
      </figcaption>
    </figure>

    <header class="svc-cat__intro">
      <div class="svc-cat__intro-copy">
        <p class="kicker">(Services)&ensp;[{category.pillar}]</p>
        <p class="svc-cat__lede">{description}</p>
      </div>
      <div class="svc-cat__intro-actions">
        <a class="btn btn--dark" href="/#book" data-book-consultation>
          <span>Book a free consultation</span>
        </a>
        <a class="btn btn--ghost" href="/services/"><span>All services</span></a>
      </div>
    </header>

    <div class="svc-search">
      <svg class="svc-search__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <circle cx="7" cy="7" r="5.25" stroke="currentColor" stroke-width="1.5" />
        <path d="M11 11L14.5 14.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
      <input
        type="search"
        id="svcCatSearch"
        placeholder="Filter services in this practice…"
        autocomplete="off"
        spellcheck="false"
        aria-label="Filter services"
      />
      <button class="svc-search__clear" id="svcCatSearchClear" type="button" aria-label="Clear search" hidden>&times;</button>
    </div>
    <p class="svc-cat__status" id="svcCatStatus" hidden></p>

    <section class="svc-cat__main" aria-label={`Services in ${category.name}`}>
      <header class="svc-cat__main-head">
        <h2>What’s included</h2>
        <p>Click any service to enquire</p>
      </header>
      <ul class="svc-cat__grid" id="svcCatGrid">
        {category.services.map((service, i) => {
          const haystack = `${service.name} ${service.description}`.toLowerCase();
          return (
            <li id={serviceId(service.name)} data-svc-cat-item data-search={haystack}>
              <button
                type="button"
                class="svc-cat__card"
                data-svc-enquire
                data-category={category.name}
                data-service={service.name}
                data-tooltip="Ask about this service"
              >
                <span class="svc-cat__card-top">
                  <span class="svc-cat__num">{String(i + 1).padStart(2, "0")}</span>
                  <span class="svc-cat__card-icon" aria-hidden="true">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                      <path d="M3 7h8M7.5 3.5 11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </span>
                <span class="svc-cat__card-name">{service.name}</span>
                <span class="svc-cat__card-desc">{service.description}</span>
              </button>
            </li>
          );
        })}
      </ul>
    </section>

    {related.length > 0 && (
      <section class="svc-cat__related">
        <header class="svc-cat__related-head">
          <p class="kicker">{siblings.length > 0 ? `Also in ${category.pillar}` : "Explore more"}</p>
          <h2>Related practices</h2>
        </header>
        <div class="svc-cat__related-grid">
          {related.map((sib) => (
            <a class="svc-cat__related-card" href={`/services/${sib.slug}/`}>
              <img
                src="/images/showreel-dubai.png"
                alt=""
                width="640"
                height="480"
                loading="lazy"
                aria-hidden="true"
              />
              <span class="svc-cat__related-copy">
                <strong>{sib.name}</strong>
                <em>{sib.pillar} · {sib.services.length}</em>
              </span>
            </a>
          ))}
        </div>
      </section>
    )}

    <nav class="svc-cat__back" aria-label="Services navigation">
      <a href="/services/">← All services</a>
      <a href="/#services">Back to homepage</a>
    </nav>
  </article>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
</BaseLayout>

<style>
  .svc-cat {
    max-width: min(var(--content-max), 72rem);
    width: 100%;
    margin-inline: auto;
    padding:
      calc(4.5rem + clamp(1.2rem, 3vh, 2rem))
      var(--gutter)
      clamp(3rem, 8vh, 5rem);
  }
  .svc-cat .scene-banner {
    margin-bottom: clamp(1.8rem, 4vh, 2.6rem);
  }
  .svc-cat .scene-banner__title {
    width: min(96%, 16ch);
    font-size: clamp(2.4rem, 6vw, 4.8rem);
  }

  .svc-cat__intro {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.25rem 2rem;
    margin-bottom: clamp(1.4rem, 3vh, 2rem);
  }
  .svc-cat__intro-copy {
    display: grid;
    gap: 0.7rem;
    max-width: 40rem;
  }
  .svc-cat__lede {
    margin: 0;
    color: var(--ink-soft);
    font-size: clamp(1.02rem, 1.8vw, 1.2rem);
    line-height: 1.55;
  }
  .svc-cat__intro-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .svc-cat .svc-search {
    margin: 0 0 1rem;
  }
  .svc-cat__status {
    margin: 0 0 1rem;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  /* Cancel global `section` side padding so this aligns with search/intro */
  .svc-cat__main,
  .svc-cat__related {
    padding: 0;
    max-width: none;
    width: 100%;
  }

  .svc-cat__main-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem 1.5rem;
    margin-bottom: 1.15rem;
  }
  .svc-cat__main-head h2 {
    margin: 0;
    font-size: clamp(1.35rem, 2.2vw, 1.75rem);
    font-weight: 600;
    letter-spacing: -0.03em;
  }
  .svc-cat__main-head p {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.9rem;
  }

  .svc-cat__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
    grid-template-columns: 1fr;
  }
  .svc-cat__grid > li.is-hidden { display: none; }

  .svc-cat__card {
    width: 100%;
    height: 100%;
    display: grid;
    gap: 0.5rem;
    text-align: left;
    padding: 1.15rem 1.2rem;
    border: 1px solid rgba(17, 17, 17, 0.08);
    border-radius: calc(var(--radius) * 0.75);
    background: var(--card);
    color: inherit;
    font: inherit;
    cursor: pointer;
    transition:
      border-color 0.3s,
      transform 0.35s var(--ease-out),
      box-shadow 0.35s var(--ease-out);
  }
  .svc-cat__card:hover,
  .svc-cat__card:focus-visible {
    border-color: rgba(17, 17, 17, 0.18);
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(17, 17, 17, 0.06);
  }
  .svc-cat__card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .svc-cat__num {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: rgba(17, 17, 17, 0.38);
    font-variant-numeric: tabular-nums;
  }
  .svc-cat__card-icon {
    width: 1.65rem;
    height: 1.65rem;
    display: grid;
    place-content: center;
    border-radius: 50%;
    border: 1px solid rgba(17, 17, 17, 0.14);
    color: rgba(17, 17, 17, 0.45);
    transition: background 0.3s, color 0.3s, border-color 0.3s, transform 0.35s var(--ease-out);
  }
  .svc-cat__card:hover .svc-cat__card-icon,
  .svc-cat__card:focus-visible .svc-cat__card-icon {
    background: var(--ink);
    border-color: var(--ink);
    color: #fff;
    transform: translateX(0.15rem);
  }
  .svc-cat__card-name {
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.25;
  }
  .svc-cat__card-desc {
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--ink-soft);
  }

  .svc-cat__related {
    margin-top: clamp(3.2rem, 8vh, 5rem);
    display: grid;
    gap: 1.4rem;
  }
  .svc-cat__related-head h2 {
    margin: 0.35rem 0 0;
    font-size: clamp(1.35rem, 2.2vw, 1.75rem);
    font-weight: 600;
    letter-spacing: -0.03em;
  }
  .svc-cat__related-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }
  .svc-cat__related-card {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: calc(var(--radius) * 0.85);
    aspect-ratio: 16 / 10;
    background: var(--dark);
    color: #fff;
    text-decoration: none;
  }
  .svc-cat__related-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1s var(--ease-out);
  }
  .svc-cat__related-card:hover img { transform: scale(1.05); }
  .svc-cat__related-copy {
    position: absolute;
    inset: auto 0 0 0;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 2.2rem 1.1rem 1rem;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.72), transparent);
  }
  .svc-cat__related-copy strong {
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .svc-cat__related-copy em {
    font-style: normal;
    font-size: 0.78rem;
    opacity: 0.75;
    white-space: nowrap;
  }

  .svc-cat__back {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 2rem;
    margin-top: clamp(2rem, 5vh, 3rem);
    padding-top: clamp(1.5rem, 3vh, 2rem);
    border-top: 1px solid var(--line);
  }
  .svc-cat__back a {
    color: var(--ink-soft);
    text-decoration: none;
    font-size: 0.95rem;
  }
  .svc-cat__back a:hover { color: var(--ink); }

  @media (min-width: 700px) {
    .svc-cat__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .svc-cat__related-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (hover: none) {
    .svc-cat__card:active {
      transform: scale(0.985);
    }
  }
</style>

<script>
  function initSvcCatSearch() {
    const root = document.getElementById("svcCatPage");
    if (!root) return;
    const input = root.querySelector("#svcCatSearch");
    const clear = root.querySelector("#svcCatSearchClear");
    const status = root.querySelector("#svcCatStatus");
    const items = [...root.querySelectorAll("[data-svc-cat-item]")];
    if (!input || !items.length) return;

    const apply = () => {
      const q = String(input.value || "").trim().toLowerCase();
      let shown = 0;
      for (const item of items) {
        const hit = !q || (item.getAttribute("data-search") || "").includes(q);
        item.classList.toggle("is-hidden", !hit);
        if (hit) shown += 1;
      }
      if (clear) clear.hidden = !q;
      if (status) {
        if (!q) {
          status.hidden = true;
          status.textContent = "";
        } else {
          status.hidden = false;
          status.textContent =
            shown === 0
              ? "No matching services"
              : `${shown} match${shown === 1 ? "" : "es"}`;
        }
      }
    };

    input.addEventListener("input", apply);
    clear?.addEventListener("click", () => {
      input.value = "";
      input.focus();
      apply();
    });
  }

  initSvcCatSearch();
  document.addEventListener("astro:page-load", initSvcCatSearch);
</script>
