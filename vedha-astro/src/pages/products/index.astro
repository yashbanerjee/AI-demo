---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const products = (await getCollection("products", ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout
  title="Products — VEDHA"
  description="Productized solutions by Vedha: e-commerce platforms, AI development, and more — scoped, priced and ready to launch."
>
  <section class="products-index">
    <header class="section-head">
      <div>
        <p class="kicker" data-reveal>(Products)</p>
        <h2 class="giant" data-reveal>Products <sup>({products.length})</sup></h2>
      </div>
      <p class="section-head__sub" data-reveal>Scoped, priced and ready to launch.</p>
    </header>
    <div class="work__grid">
      {products.map((product) => (
        <a class="work-card" href={`/products/${product.id}/`} data-reveal>
          <figure>
            <img src={product.data.image} alt={`${product.data.title} — ${product.data.tagline}`} width="900" height="1100" loading="lazy" />
          </figure>
          <p><strong>{product.data.title}</strong><span>({product.data.category})</span></p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  /* Clear the fixed header on subpages */
  .products-index { padding-top: calc(4.5rem + clamp(2rem, 6vh, 4rem)); }
</style>
