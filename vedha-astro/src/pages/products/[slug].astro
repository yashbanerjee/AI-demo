---
import { getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const product = await getEntry("products", Astro.params.slug!);
if (!product || product.data.draft) {
  return new Response("Not found", { status: 404 });
}

const { Content } = await render(product);
const { title, tagline, description, category, image, price, timeline, features } = product.data;
---
<BaseLayout title={`${title} — VEDHA`} description={description} ogImage={image}>
  <section class="product-hero">
    <p class="kicker" data-reveal>(Product)&ensp;[{category}]</p>
    <h1 class="giant" data-reveal>{title}</h1>
    <p class="product-hero__tagline" data-reveal>{tagline}</p>
    <figure class="product-hero__media" data-reveal>
      <img src={image} alt={`${title} — ${tagline}`} width="1600" height="900" />
    </figure>
  </section>

  <section class="product-body">
    <div class="product-body__prose" data-reveal>
      <Content />
    </div>
    <aside class="price-card product-body__card" data-reveal>
      <header>
        <h3>{title}</h3>
        <p>{description}</p>
      </header>
      {price && <p class="price-card__price">{price.replace(/^From /, "")} <span>/ starting price</span></p>}
      {features.length > 0 && (
        <>
          <p class="price-card__label">What’s included:</p>
          <ul>
            {features.map((feature) => <li>{feature}</li>)}
          </ul>
        </>
      )}
      {timeline && <p class="price-card__timeline">Timeline: <b>{timeline}</b></p>}
      <a class="btn btn--dark btn--wide" href="/#book" data-book-consultation><span>Book a free consultation</span></a>
    </aside>
  </section>
</BaseLayout>

<style>
  /* Clear the fixed header on subpages */
  .product-hero {
    padding-top: calc(4.5rem + clamp(2rem, 6vh, 4rem));
    padding-bottom: 0;
    display: grid;
    gap: 1.2rem;
  }
  .product-hero__tagline {
    color: var(--ink-soft);
    font-size: clamp(1.1rem, 2.2vw, 1.5rem);
    max-width: 32rem;
  }
  .product-hero__media {
    margin-top: clamp(1.5rem, 4vh, 3rem);
    overflow: hidden;
    border-radius: var(--radius);
    aspect-ratio: 16 / 9;
    background: #ddd;
  }
  .product-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-body {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1fr;
    align-items: start;
  }
  .product-body__prose {
    max-width: 42rem;
    display: grid;
    gap: 1.2rem;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--ink);
  }
  .product-body__card { position: sticky; top: 5.5rem; }

  @media (min-width: 48rem) {
    .product-body { grid-template-columns: 3fr 2fr; gap: clamp(2rem, 5vw, 5rem); }
  }
</style>
