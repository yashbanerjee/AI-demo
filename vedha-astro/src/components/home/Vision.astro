<!-- ===== Process: 3D card stack → lined-up finale ===== -->
<section class="process" id="vision">
  <div class="process__sticky">
    <header class="process__head">
      <p class="kicker kicker--light">(Our Process)</p>
      <p class="process__count" id="processCount" aria-hidden="true">
        <span id="processCurrent">01</span><span>/</span><span>05</span>
      </p>
    </header>

    <div class="process__stage" id="processStage">
      <article class="process-card is-active" data-process-card>
        <span class="process-card__num">01</span>
        <h3>Discover</h3>
        <p>We learn your goals, users, and constraints before a single line of code.</p>
      </article>
      <article class="process-card" data-process-card>
        <span class="process-card__num">02</span>
        <h3>Chart</h3>
        <p>A clear roadmap with milestones, scope, and priorities you can trust.</p>
      </article>
      <article class="process-card" data-process-card>
        <span class="process-card__num">03</span>
        <h3>Validate</h3>
        <p>Prototypes and reviews so decisions land early — not at the finish line.</p>
      </article>
      <article class="process-card" data-process-card>
        <span class="process-card__num">04</span>
        <h3>Engineer</h3>
        <p>Senior-led build with clean architecture, performance, and polish.</p>
      </article>
      <article class="process-card" data-process-card>
        <span class="process-card__num">05</span>
        <h3>Scale</h3>
        <p>Launch, measure, and iterate — so the product keeps growing with you.</p>
      </article>
    </div>

    <div class="process__dots" id="processDots" aria-hidden="true">
      <i class="is-active"></i><i></i><i></i><i></i><i></i>
    </div>
  </div>
</section>
