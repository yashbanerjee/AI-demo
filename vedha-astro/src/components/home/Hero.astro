<!-- ===== Hero: white card scales away over collage ===== -->
<section class="hero" id="hero">
  <div class="hero__sticky">
    <!-- Collage revealed behind the card -->
    <div class="hero__collage" aria-hidden="true">
      <div class="collage-grid">
        <img src="/images/hero-collage-1.png" alt="" width="1024" height="682" />
        <img src="/images/hero-collage-2.png" alt="" width="1024" height="682" />
        <img src="/images/hero-collage-3.png" alt="" width="1024" height="682" />
        <img src="/images/hero-collage-4.png" alt="" width="1024" height="682" />
        <img src="/images/hero-collage-5.png" alt="" width="1024" height="682" />
        <img src="https://picsum.photos/seed/mono-f/640/480" alt="" width="640" height="480" />
        <img src="https://picsum.photos/seed/mono-g/640/640" alt="" width="640" height="640" />
        <img src="https://picsum.photos/seed/mono-h/640/480" alt="" width="640" height="480" />
        <img src="https://picsum.photos/seed/mono-i/640/800" alt="" width="640" height="800" />
      </div>
    </div>
    <!-- White hero card -->
    <div class="hero__card" id="heroCard">
      <div class="hero__top">
        <ul class="hero__services split-lines">
          <li>Web Development</li>
          <li>UI/UX Design</li>
          <li>E-Commerce</li>
          <li>AI Development</li>
          <li>Digital Transformation</li>
        </ul>
        <div class="hero__pitch">
          <p class="split-lines">From web development to cloud solutions, mobile apps to digital transformation — end-to-end tech services that drive growth and innovation. Trusted by more than 100 brands.</p>
          <a class="btn btn--dark" href="/#contact"><span>Book a free consultation</span></a>
        </div>
      </div>
      <div class="hero__mid" aria-hidden="true">
        <span class="dot"></span><span class="dot"></span><span class="dot"></span><span class="dot"></span>
      </div>
      <p class="hero__copyright">© 2026 Vedha Technologies LLC-FZ</p>
      <h1 class="hero__title">
        <span class="hero__word" data-reveal>VEDHA</span>
        <span class="hero__word hero__word--right" data-reveal>Tech</span>
      </h1>
      <div class="hero__foot">
        <span class="tag">Scroll Down</span>
        <span class="hero__meta">(Trusted by 100+ brands)</span>
        <span class="hero__meta">(Portfolio 26©)</span>
      </div>
    </div>
  </div>
</section>
