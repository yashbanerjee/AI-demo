---
const cards = [
  {
    label: "Years of experience",
    count: 10,
    suffix: "+",
    blurb: "Strategy, tech, and a touch of clever.",
    tag: "Boutique, senior-led",
    quote: "We work with a limited number of clients to keep senior-level oversight on every project.",
  },
  {
    label: "Solutions delivered",
    count: 120,
    suffix: "+",
    blurb: "Driving outcomes across industries.",
    tag: "Future-ready tech",
    quote: "Scalable platforms with clean architecture — AI only where it genuinely adds value.",
  },
  {
    label: "Client satisfaction",
    count: 98,
    suffix: "%",
    blurb: "Partnerships built on trust.",
    tag: "Clear communication",
    quote: "Transparent process, simple updates — clients always know what’s happening and why.",
  },
  {
    label: "Long-term clients",
    count: 100,
    suffix: "+",
    blurb: "Built for lasting partnerships.",
    tag: "Beyond launch",
    quote: "We prioritise relationships that keep delivering value well after go-live.",
  },
];
---

<!-- ===== Stats ===== -->
<section class="stats" id="stats">
  <figure class="scene-banner" data-scene-banner>
    <img
      src="/images/photo-alpine-glow.jpg"
      alt=""
      width="1920"
      height="1282"
      loading="lazy"
      aria-hidden="true"
    />
    <h2 class="scene-banner__title">Vedha stands behind the data.</h2>
    <figcaption class="scene-banner__meta">
      <span>Outcomes</span>
      <a href="/#contact">Let’s talk</a>
    </figcaption>
  </figure>
  <p class="stats__lead" data-reveal>
    Our success is reflected in the numbers we achieve for our clients. Every project is designed with measurable growth at its core.
  </p>
  <div class="stats__grid">
    {cards.map((card, i) => (
      <article class="stat-card" data-reveal>
        <header class="stat-card__top">
          <p class="stat-card__label">{card.label}</p>
          <p
            class="stat-card__num"
            data-count={String(card.count)}
            data-suffix={card.suffix}
          >{card.count}{card.suffix}</p>
          <p class="stat-card__blurb">{card.blurb}</p>
        </header>
        <footer class="stat-card__quote">
          <div class="stat-card__tag">
            <span class="stat-card__index">{String(i + 1).padStart(3, "0")}</span>
            <span class="stat-card__topic">{card.tag}</span>
          </div>
          <p class="stat-card__stars" aria-label="5 out of 5">
            <span aria-hidden="true">★★★★★</span>
          </p>
          <p class="stat-card__text">“{card.quote}”</p>
          <cite class="stat-card__author">Vedha Team</cite>
        </footer>
      </article>
    ))}
  </div>
</section>
