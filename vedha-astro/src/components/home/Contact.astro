<!-- ===== Contact ===== -->
<section class="contact" id="contact">
  <div class="contact__left">
    <p class="kicker" data-reveal>(Contact us)</p>
    <h2 class="giant" data-reveal>Let’s talk.</h2>
    <p data-reveal>Let’s create new experiences. Book a free consultation and tell us about your project.</p>
  </div>
  <form class="contact__form" data-reveal>
    <div class="field-row">
      <label>First name<input type="text" name="firstName" placeholder="First name" required autocomplete="given-name" /></label>
      <label>Last name<input type="text" name="lastName" placeholder="Last name" autocomplete="family-name" /></label>
    </div>
    <label>Email<input type="email" name="email" placeholder="Email" required autocomplete="email" /></label>
    <button class="btn btn--dark btn--wide" type="submit"><span>Contact Us</span></button>
    <p class="contact__terms">By contacting us, you accept our <a href="/#contact">Terms</a> and <a href="/#contact">Privacy Policy</a>.</p>
  </form>
</section>
