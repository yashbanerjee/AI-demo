<!-- ===== Alternative Hero: 3D video scrubbed by scroll, ends on logo ===== -->
<section class="hero-video" id="heroVideo">
  <div class="hero-video__sticky">
    <video
      class="hero-video__media"
      id="heroVideoMedia"
      src="/videos/hero-3d.mp4"
      poster="/videos/hero-3d-poster.jpg"
      muted
      playsinline
      preload="auto"
      aria-hidden="true"
    ></video>
    <!-- End state: page background + logo + CTAs, revealed once the video finishes -->
    <div class="hero-video__end" id="heroVideoEnd" aria-hidden="true">
      <div class="hero-video__end-inner">
        <img class="hero-video__logo" src="/images/vedha-logo.png" alt="" width="1483" height="158" />
        <div class="hero-video__ctas">
          <a class="btn btn--dark" href="/#book" data-book-consultation><span>Book free consultation</span></a>
          <a class="btn btn--ghost" href="/#enquiry"><span>Send us an enquiry</span></a>
        </div>
      </div>
    </div>
    <!-- Intro state: black cover shown on load, the video emerges as you scroll -->
    <div class="hero-video__intro" id="heroVideoIntro" aria-hidden="true">
      <span>Scroll to explore</span>
    </div>
  </div>
  <h1 class="visually-hidden">VEDHA — Your Complete Technology Partner for Digital Success</h1>
</section>
