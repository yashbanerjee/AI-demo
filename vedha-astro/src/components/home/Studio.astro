<!-- ===== Studio / Who we are ===== -->
<section class="studio" id="studio">
  <p class="kicker" data-reveal>(Who we are)&ensp;[VEDHA — Dubai]</p>

  <figure class="scene-banner" data-scene-banner>
    <img
      src="/images/showreel-dubai.png"
      alt="Dubai skyline — Vedha’s home base"
      width="1600"
      height="900"
      loading="lazy"
    />
    <h2 class="scene-banner__title">
      <span class="scene-banner__line">Your complete</span>
      <span class="scene-banner__line">technology partner</span>
      <span class="scene-banner__line">for digital success.</span>
    </h2>
    <figcaption class="scene-banner__meta">
      <span>Dubai</span>
      <span>Built for the region · Delivered worldwide</span>
    </figcaption>
  </figure>

  <div class="studio__cards">
    <article class="s-card" data-reveal>
      <p class="kicker">(Top quality)</p>
      <div class="avatars" aria-hidden="true">
        <img src="https://picsum.photos/seed/vedha-face-a/96/96" alt="" width="96" height="96" loading="lazy" />
        <img src="https://picsum.photos/seed/vedha-face-b/96/96" alt="" width="96" height="96" loading="lazy" />
        <img src="https://picsum.photos/seed/vedha-face-c/96/96" alt="" width="96" height="96" loading="lazy" />
        <span>+1</span>
      </div>
      <p class="s-card__big">Built by senior engineers <small>crafted for brands that care about detail</small></p>
    </article>
    <article class="s-card s-card--dark" data-reveal>
      <p class="kicker">(Streamlined processes)</p>
      <p class="s-card__stat">Delivery time <b>−40%</b></p>
      <p class="s-card__stat">Handoffs <b>−2 weeks</b></p>
      <div class="s-card__bars" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></div>
    </article>
    <article class="s-card s-card--photo" data-reveal>
      <img
        class="s-card__bg"
        src="/images/hero-collage-4.png"
        alt=""
        width="1024"
        height="576"
        loading="lazy"
        aria-hidden="true"
      />
      <p class="s-card__big">Flexible &amp; transparent pricing</p>
      <a class="btn btn--light" href="/#contact"><span>Get a quote</span></a>
    </article>
    <article class="s-card s-card--chat" data-reveal>
      <p class="kicker">(Clear communications)</p>
      <p class="chat__time">Today 17:01</p>
      <p class="chat__bubble">Can we review the sprint goals?</p>
      <p class="chat__bubble">Need the timeline by Friday</p>
      <p class="chat__time">Today 17:02</p>
      <p class="chat__bubble chat__bubble--me">Shared — milestones locked in</p>
      <p class="chat__bubble">Perfect, thanks Vedha.</p>
    </article>
  </div>
</section>
