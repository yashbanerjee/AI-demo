---
import { listPosts } from "../../lib/db";

const posts = (await listPosts()).slice(0, 4);

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---
<!-- ===== Blog ===== -->
<section class="blog" id="news">
  <figure class="scene-banner" data-scene-banner>
    <img
      src="/images/showreel-dubai.png"
      alt=""
      width="1800"
      height="1000"
      loading="lazy"
      aria-hidden="true"
    />
    <h2 class="scene-banner__title">Smart insights.</h2>
    <figcaption class="scene-banner__meta">
      <span>Blog</span>
      <a href="/blog/">See all</a>
    </figcaption>
  </figure>
  <ul class="blog__list">
    {posts.map((post, i) => (
      <li data-reveal>
        <a href={`/blog/${post.slug}/`} class="blog-row">
          <figure class="blog-row__media">
            <img
              src={post.cover_image || "/images/showreel-dubai.png"}
              alt={`${post.title} article cover`}
              width="480"
              height="360"
              loading="lazy"
            />
          </figure>
          <div class="blog-row__copy">
            <time datetime={post.pub_date.toISOString().split("T")[0]}>{formatDate(post.pub_date)}</time>
            <h3>{post.title}</h3>
          </div>
          <span class="blog-row__arrow" aria-hidden="true">→</span>
        </a>
      </li>
    ))}
  </ul>
</section>
