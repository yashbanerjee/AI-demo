---
import { faqPageSchema } from "../../lib/schema";

const questions = [
  {
    question: "What services does Vedha offer?",
    answer:
      "Eight pillars spanning Consult, Design, Build, Automate, Intelligence, Connect, Scale, and Support — covering strategy, AI, automation, enterprise software, product design, integrations, infrastructure, and ongoing managed teams.",
  },
  {
    question: "How do you determine the right strategy?",
    answer:
      "We follow a five-step process — Discover, Chart, Validate, Engineer, Scale. We dig into your brand and workflows first, then combine data, experience and your insider knowledge to map the smartest path forward.",
  },
  {
    question: "How much does it cost to work with you?",
    answer:
      "Costs depend on scope, features and complexity. We price projects based on business goals and technical requirements, so you pay for what your business actually needs.",
  },
  {
    question: "Do you work with businesses outside Dubai?",
    answer:
      "Yes. While based in Dubai, we work with businesses across the UAE and internationally, with processes designed for smooth remote collaboration.",
  },
];
const schema = faqPageSchema(questions);
---

<!-- ===== FAQ ===== -->
<section class="faq" id="faq">
  <figure class="scene-banner" data-scene-banner>
    <img
      src="/images/hero-collage-8.png"
      alt=""
      width="1800"
      height="1000"
      loading="lazy"
      aria-hidden="true"
    />
    <h2 class="scene-banner__title">FAQ</h2>
    <figcaption class="scene-banner__meta">
      <span>Answers</span>
      <span>Straight talk · No fluff</span>
    </figcaption>
  </figure>
  <div class="faq__list">
    <details class="faq__item" data-reveal>
      <summary><span>01</span>{questions[0].question}<i aria-hidden="true"></i></summary>
      <p>{questions[0].answer}</p>
    </details>
    <details class="faq__item" data-reveal>
      <summary><span>02</span>{questions[1].question}<i aria-hidden="true"></i></summary>
      <p>{questions[1].answer}</p>
    </details>
    <details class="faq__item" data-reveal>
      <summary><span>03</span>{questions[2].question}<i aria-hidden="true"></i></summary>
      <p>{questions[2].answer}</p>
    </details>
    <details class="faq__item" data-reveal>
      <summary><span>04</span>{questions[3].question}<i aria-hidden="true"></i></summary>
      <p>{questions[3].answer}</p>
    </details>
  </div>
  <aside class="faq__more" data-reveal>
    <figure class="faq__more-media" aria-hidden="true">
      <img src="/images/hero-collage-8.png" alt="" width="1024" height="682" loading="lazy" />
    </figure>
    <div class="faq__more-copy">
      <p class="kicker">(Looking for more?)</p>
      <h4>Expand your scope with AI,<br />cloud solutions, or mobile apps.</h4>
      <a class="btn btn--dark" href="/#book" data-book-consultation><span>Book a free consultation</span></a>
    </div>
  </aside>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
</section>
