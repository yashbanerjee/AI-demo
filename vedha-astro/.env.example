# Postgres connection string. Locally this points at the embedded Postgres
# started by `npm run db:start`; in production use your managed Postgres URL.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/vedha

# Password for the /admin panel login.
ADMIN_PASSWORD=change-me

# Random secret used to sign admin session cookies (e.g. `openssl rand -hex 32`).
SESSION_SECRET=change-me
